<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Svg.Controls.Skia.Avalonia"

             x:Class="AvaloniaUI.SVG.App"
             xmlns:local="using:AvaloniaUI.SVG"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />
    </Application.Styles>

    <!--dynamic resource-->
    <Application.Resources>
        <ResourceDictionary>
            <svg:SvgImage x:Key="CameraIcon"
                          Source="/Assets/CPU.svg"/>
            <svg:SvgImage x:Key="SettingsIcon"
                          Source="/Assets/CPU.svg"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>