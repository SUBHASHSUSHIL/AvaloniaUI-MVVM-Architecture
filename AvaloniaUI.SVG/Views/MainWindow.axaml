<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AvaloniaUI.SVG.ViewModels"
        xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Svg.Controls.Skia.Avalonia"
        x:Class="AvaloniaUI.SVG.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="AvaloniaUI.SVG">

    <StackPanel>
        <Grid>

            <TextBlock Text="{Binding Greeting}"
                       HorizontalAlignment="Center"/>

            <svg:Svg Width="120"
                     Height="120"
                     Path="avares://AvaloniaUI.SVG/Assets/CPU.svg"/>

        </Grid>
    </StackPanel>

</Window>